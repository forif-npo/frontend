{
  "name": "@repo/ui",
  "version": "0.0.0",
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./styles.css": "./dist/styles.css",
    "./theme.css": "./src/theme.css",
    "./components/server": "./src/components/server/index.ts",
    "./components/client": "./src/components/client/index.ts",
    "./theme-provider": "./src/provider.tsx",
    "./colors": "./src/colors/color.ts"
  },
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/styles.css",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/assets": "workspace:*",
    "@repo/core": "workspace:*",
    "@tailwindcss/cli": "^4.1.7",
    "clsx": "^2.1.1",
    "next": "15.3.2",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@repo/eslint-config": "workspace:*",
    "@repo/tailwind-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.17.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "jest": "^29.7.0",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=7.0.0"
  }
}