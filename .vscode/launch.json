{
  "version": "0.2.0",
  // Launch configurations for FORIF monorepo (web + admin + tooling)
  "configurations": [
    // ================= WEB APP =================
    {
      "name": "Next.js (web): Server",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm run dev",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Next.js (web): Client (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/apps/web",
      "sourceMaps": true
    },
    // (Optional) Firefox config removed: requires separate extension. Add later if extension installed.
    // ================= ADMIN APP =================
    {
      "name": "Next.js (admin): Server (Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm -F admin dev --port 3100",
      "cwd": "${workspaceFolder}/apps/admin"
    },
    {
      "name": "Next.js (admin): Server (inspect)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
      "args": ["dev", "apps/admin", "-p", "3100"],
      "cwd": "${workspaceFolder}",
      "runtimeArgs": ["--inspect"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "FORIF_APP": "admin"
      },
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s"
      }
    },
    {
      "name": "Next.js (admin): Client (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3100",
      "webRoot": "${workspaceFolder}/apps/admin",
      "sourceMaps": true
    },
    // ================= SHARED / TOOLING =================
    {
      "name": "Storybook (ui)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm storybook",
      "cwd": "${workspaceFolder}",
      "env": {
        "STORYBOOK": "true"
      }
    },
    {
      "name": "Attach to Node (pick process)",
      "type": "node",
      "request": "attach",
      "processId": "${command:PickProcess}",
      "skipFiles": ["<node_internals>/**"],
      "restart": true
    },
    {
      "name": "Jest (web)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/web",
      "program": "${workspaceFolder}/apps/web/node_modules/jest/bin/jest.js",
      "args": [
        "--runInBand",
        "--config",
        "${workspaceFolder}/packages/jest-presets/node/jest.config.js",
        "--watchAll=false"
      ],
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "console": "integratedTerminal"
    }
  ]
}
